# Base de datos (PostgreSQL en Vercel/Neon o Supabase)
DATABASE_URL="postgresql://usuario:password@host:5432/estudio_pvc"

# Resend - para emails de notificación de turnos
# Crear cuenta gratuita en https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="turnos@peraltaveracostanzo.com.ar"
EMAIL_ADMIN="estudio@peraltaveracostanzo.com.ar"

# Admin panel - clave simple para proteger el panel
ADMIN_SECRET="cambiar-por-clave-segura"

# URL del sitio (para links en emails)
NEXT_PUBLIC_SITE_URL="https://peraltaveracostanzo.com.ar"
